{
  "name": "@flamel-ai/yext-api",
  "version": "0.1.4",
  "packageManager": "pnpm@10.33.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "description": "Clean, fully-typed TypeScript SDK for the Yext API, generated from the official OpenAPI specs with zod validation. Covers all 11 Yext APIs.",
  "type": "module",
  "license": "BSD-3-Clause",
  "author": "Flamel AI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flamel-ai/yext-api.git"
  },
  "homepage": "https://github.com/flamel-ai/yext-api#readme",
  "bugs": {
    "url": "https://github.com/flamel-ai/yext-api/issues"
  },
  "keywords": [
    "yext",
    "sdk",
    "openapi",
    "typescript",
    "zod",
    "knowledge-graph",
    "listings"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "specs",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js",
      "require": "./dist/auth.cjs",
      "default": "./dist/auth.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js",
      "require": "./dist/errors.cjs",
      "default": "./dist/errors.js"
    },
    "./admin": {
      "types": "./dist/admin/index.d.ts",
      "import": "./dist/admin/index.js",
      "require": "./dist/admin/index.cjs",
      "default": "./dist/admin/index.js"
    },
    "./answers": {
      "types": "./dist/answers/index.d.ts",
      "import": "./dist/answers/index.js",
      "require": "./dist/answers/index.cjs",
      "default": "./dist/answers/index.js"
    },
    "./chat": {
      "types": "./dist/chat/index.d.ts",
      "import": "./dist/chat/index.js",
      "require": "./dist/chat/index.cjs",
      "default": "./dist/chat/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js",
      "require": "./dist/events/index.cjs",
      "default": "./dist/events/index.js"
    },
    "./knowledge": {
      "types": "./dist/knowledge/index.d.ts",
      "import": "./dist/knowledge/index.js",
      "require": "./dist/knowledge/index.cjs",
      "default": "./dist/knowledge/index.js"
    },
    "./live": {
      "types": "./dist/live/index.d.ts",
      "import": "./dist/live/index.js",
      "require": "./dist/live/index.cjs",
      "default": "./dist/live/index.js"
    },
    "./publisher-ecl": {
      "types": "./dist/publisher-ecl/index.d.ts",
      "import": "./dist/publisher-ecl/index.js",
      "require": "./dist/publisher-ecl/index.cjs",
      "default": "./dist/publisher-ecl/index.js"
    },
    "./listings": {
      "types": "./dist/listings/index.d.ts",
      "import": "./dist/listings/index.js",
      "require": "./dist/listings/index.cjs",
      "default": "./dist/listings/index.js"
    },
    "./publisher-notify-review": {
      "types": "./dist/publisher-notify-review/index.d.ts",
      "import": "./dist/publisher-notify-review/index.js",
      "require": "./dist/publisher-notify-review/index.cjs",
      "default": "./dist/publisher-notify-review/index.js"
    },
    "./publisher-tracking-pixel": {
      "types": "./dist/publisher-tracking-pixel/index.d.ts",
      "import": "./dist/publisher-tracking-pixel/index.js",
      "require": "./dist/publisher-tracking-pixel/index.cjs",
      "default": "./dist/publisher-tracking-pixel/index.js"
    },
    "./webhooks": {
      "types": "./dist/webhooks/index.d.ts",
      "import": "./dist/webhooks/index.js",
      "require": "./dist/webhooks/index.cjs",
      "default": "./dist/webhooks/index.js"
    }
  },
  "scripts": {
    "fetch-specs": "tsx scripts/fetch-specs.ts",
    "generate": "tsx scripts/generate.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run test/integration.test.ts",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.98.2",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
